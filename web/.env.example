# PostgreSQL（本地：先 docker compose up -d，见 web/docker-compose.yml）
DATABASE_URL="postgresql://gant:gant_dev_password@localhost:5432/gant?schema=public"

# 种子脚本为用户写入的初始登录密码（可改；勿提交真实生产密码）
SEED_DEFAULT_PASSWORD="11111111"

# 用于签名浏览器 Cookie 中的会话（请改为随机长串）
SESSION_SECRET="dev-only-change-in-production-use-openssl-rand-hex-32"

# 开发期：AUTH_DEV=1 时在登录页显示「免密选用户」快捷入口。生产务必设为 0。
AUTH_DEV="1"
