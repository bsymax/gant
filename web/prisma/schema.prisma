generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 无原生 enum，用 String + 应用层约束（PostgreSQL 同理）
model User {
  id        String   @id @default(cuid())
  erp       String   @unique
  name      String
  role      String // LEAD | MEMBER
  /// bcrypt 哈希；空字符串表示尚未设置，禁止密码登录
  passwordHash String @default("")
  avatarUrl String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectMembers           ProjectMember[]
  taskAssignees            TaskAssignee[]
  ownedTasks               Task[]                   @relation("TaskOwner")
  auditLogs                AuditLog[]
  weeklyOutcomesUpdated    TaskWeeklyOutcome[]      @relation("WeeklyOutcomeUpdatedBy")
  weeklyAllocations        MemberWeeklyAllocation[] @relation("WeeklyAllocationUser")
  weeklyAllocationsUpdated MemberWeeklyAllocation[] @relation("WeeklyAllocationUpdatedBy")
  projectWeeklyTracksUpdated ProjectWeeklyTrack[]   @relation("ProjectWeeklyTrackUpdatedBy")
  taskWeeklyTracksUpdated    TaskWeeklyTrack[]      @relation("TaskWeeklyTrackUpdatedBy")
}

model Project {
  id           String    @id @default(cuid())
  title        String
  description  String    @default("")
  /// PLANNING | IN_PROGRESS | NEED_ATTENTION | AT_RISK | CLOSED
  status       String    @default("PLANNING")
  scheduleMode String    @default("IN_RESERVE") // IN_RESERVE | ON_TIMELINE（未钉日期则 planned 为空，界面单列展示）
  plannedStart DateTime?
  plannedEnd   DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members           ProjectMember[]
  tasks             Task[]
  weeklyAllocations MemberWeeklyAllocation[]
  weeklyTracks      ProjectWeeklyTrack[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Task {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 子任务时指向父任务；仅支持一层子任务
  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]  @relation("Subtasks")

  title       String
  description String  @default("")
  /// PENDING_START | IN_PROGRESS | BLOCKED | PENDING_ACCEPTANCE | COMPLETED | CANCELLED
  status      String  @default("PENDING_START")
  /// P0 | P1 | P2
  priority    String?
  /// 0-100
  progress    Int     @default(0)

  dependencyParty   String?
  metric            String?
  /// status=CANCELLED 时说明
  cancelReason      String?
  plannedStart      DateTime?
  plannedAcceptance DateTime?
  plannedEnd        DateTime?
  sortOrder         Int     @default(0)
  /// 主 R（必有一人）
  ownerUserId       String
  owner             User      @relation("TaskOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  /// 仅「支持」角色，非必；主 R 在 ownerUserId
  assignees         TaskAssignee[]
  weeklyOutcomes    TaskWeeklyOutcome[]
  weeklyAllocations MemberWeeklyAllocation[]
  weeklyTracks      TaskWeeklyTrack[]

  @@index([projectId, parentTaskId])
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // PROJECT | TASK
  entityId   String
  action     String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  diffJson   String
  createdAt  DateTime @default(now())
}

model TaskWeeklyOutcome {
  id              String   @id @default(cuid())
  taskId          String
  weekStart       DateTime
  /// HIT | PARTIAL | MISS
  outcomeStatus   String
  plannedProgress Int?
  actualProgress  Int?
  note            String   @default("")
  updatedByUserId String
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  updatedBy User @relation("WeeklyOutcomeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([taskId, weekStart])
  @@index([weekStart])
}

model MemberWeeklyAllocation {
  id              String   @id @default(cuid())
  weekStart       DateTime
  userId          String
  projectId       String
  taskId          String?
  /// 0-100，可超配，项目/任务层累加
  allocationPct   Int
  note            String   @default("")
  updatedByUserId String
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user      User    @relation("WeeklyAllocationUser", fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  updatedBy User    @relation("WeeklyAllocationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([weekStart, userId, projectId, taskId])
  @@index([weekStart, userId])
  @@index([projectId, weekStart])
}

model ProjectWeeklyTrack {
  id              String   @id @default(cuid())
  projectId       String
  weekStart       DateTime
  /// PLANNING | IN_PROGRESS | NEED_ATTENTION | AT_RISK | CLOSED
  plannedStatus   String
  /// PLANNING | IN_PROGRESS | NEED_ATTENTION | AT_RISK | CLOSED
  actualStatus    String
  note            String   @default("")
  updatedByUserId String
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedBy User    @relation("ProjectWeeklyTrackUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([projectId, weekStart])
  @@index([weekStart])
  @@index([projectId, weekStart])
}

model TaskWeeklyTrack {
  id              String   @id @default(cuid())
  taskId          String
  weekStart       DateTime
  /// PENDING_START | IN_PROGRESS | BLOCKED | PENDING_ACCEPTANCE | COMPLETED | CANCELLED
  plannedStatus   String
  /// PENDING_START | IN_PROGRESS | BLOCKED | PENDING_ACCEPTANCE | COMPLETED | CANCELLED
  actualStatus    String
  note            String   @default("")
  updatedByUserId String
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  updatedBy User @relation("TaskWeeklyTrackUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([taskId, weekStart])
  @@index([weekStart])
  @@index([taskId, weekStart])
}
